# Ne jamais committer un fichier .env réel contenant les vraies valeurs.

# Auth de l'app (protège toute la PWA + l'API)
APP_USER=admin
APP_PASSWORD=change-moi

# Auth de l'interface n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-moi-aussi

# Webhook Discord (messages motivants)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/yyyy

# URL du webhook n8n appelé par le backend à chaque séance loggée
# (visible dans n8n : node "Séance terminée (webhook)" -> onglet Webhook -> Production URL)
N8N_WEBHOOK_URL=http://n8n:5678/webhook/session-done

GENERIC_TIMEZONE=Africa/Casablanca
TZ=Africa/Casablanca
